body {
  background: #ffeef0; /* jemné pastelové pozadie */
  font-family: "Comic Sans MS", cursive, sans-serif;
  text-align: center;
  padding-top: 50px;
}

h1 {
  color: #ff69b4;
}

/* Obálka */
.envelope {
  width: 300px;
  height: 180px;
  margin: 50px auto;
  position: relative;
}

/* Flap obálky */
.flap {
  width: 100%;
  height: 80px;
  background: #ffffff; /* biela obálka */
  border: 2px solid #ff69b4;
  border-radius: 8px 8px 0 0;
  line-height: 80px;
  font-size: 24px;
  color: #ff69b4; /* srdiečko */
  cursor: pointer;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
}

/* List */
.letter {
  width: 100px; /* užší list */
  height: 500px; /* vysoký list */
  background: #fff8f0; /* jemný pastelový papier */
  border: 2px solid #ff69b4;
  border-radius: 8px; /* jemné rohy */
  display: none; /* skrytý na začiatku */
  padding: 20px;
  box-sizing: border-box;
  margin: 0 auto; /* centrovaný na stránke */
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
  flex-direction: column;
}

.letter p {
  color: #c71585;
  font-size: 16px;
  line-height: 1.5;
}
.letter {
  transition: opacity 0.8s, transform 0.8s;
  transform: translateY(-20px);
}

.letter.show {
  opacity: 1;
  transform: translateY(0);
}
.letter {
  width: 220px;          /* na výšku, nie na šírku */
  min-height: 300px;
  background: #fff8f0;
  border: 2px solid #ff69b4;
  border-radius: 10px;
  padding: 20px;
  box-sizing: border-box;

  display: none;         /* DÔLEŽITÉ – list neexistuje, kým neklikneš */
  margin: 0 auto;

  animation: fadeIn 0.6s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
const flap = document.getElementById("flap");
const letter = document.getElementById("letter");

flap.addEventListener("click", () => {
  flap.style.display = "none"; // flap zmizne
  letter.style.display = "block"; // objaví sa list so správou
});
letter.classList.add("show");
